# Copy to .env and fill in. NEVER commit .env.

# --- Official paid providers only ---
PERPLEXITY_API_KEY=replace_me
PRIMARY_LLM_PROVIDER=aiand
PRIMARY_LLM_MODEL=zai-org/glm-5.2
AIAND_API_KEY=replace_me
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=zai-org/glm-5.2
AIAND_REASONING_EFFORT=xhigh
AIAND_MAX_WORKERS=2
GOOGLE_GENAI_API_KEY=replace_me
GOOGLE_GENAI_MODEL=gemini-3.1-pro-preview
GOOGLE_THINKING_LEVEL=medium
LLM_TIMEOUT_SECONDS=180
GOOGLE_MAX_WORKERS=2

# Hard per-run safety caps. out/usage.json records estimated spend.
PERPLEXITY_RUN_BUDGET_USD=2
AIAND_RUN_BUDGET_USD=50
GOOGLE_RUN_BUDGET_USD=8
PERPLEXITY_SEARCH_CACHE_DAYS=7

# --- Composio (toolkit lookup + MCP hint) ---
COMPOSIO_API_KEY=replace_me

# --- Optional: Browser Use Cloud verification loop (browser_verify.py, runs in .venv-browser) ---
# BROWSER_USE_API_KEY=replace_me

# --- Optional: read-only Composio tool-call demo (demo/composio_demo.py) ---
# COMPOSIO_DEMO_TOOLKIT=github
# COMPOSIO_DEMO_USER_ID=default
