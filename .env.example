# Copy to .env and fill in. NEVER commit .env.

# --- LLM chain (OpenAI-compatible gateways) ---
# Ordered fallback chain. Default: AgentRouter Claude Opus -> ZenMux Claude -> OpenRouter Tencent Hy3.
LLM_PROVIDER=agentrouter
LLM_MODEL=claude-opus-4-7
LLM_FALLBACK_PROVIDER=zenmux
LLM_FALLBACK_MODEL=anthropic/claude-fable-5-free
LLM_FALLBACK2_PROVIDER=openrouter
LLM_FALLBACK2_MODEL=tencent/hy3:free
LLM_TIMEOUT_SECONDS=75

# AgentRouter OpenAI-compatible endpoint. Use /v1 here.
AGENTROUTER_BASE_URL=https://agentrouter.org/v1
AGENTROUTER_API_KEY=replace_me
AGENTROUTER_MODEL=claude-opus-4-7

# ZenMux (https://zenmux.ai)
ZENMUX_BASE_URL=https://zenmux.ai/api/v1
ZENMUX_API_KEY=replace_me

# OpenRouter (https://openrouter.ai) — used as the fallback provider
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace_me

# --- Composio (used only for the toolkit lookup + MCP hint) ---
COMPOSIO_API_KEY=replace_me

# --- Optional attribution headers providers show on your dashboard ---
APP_PUBLIC_URL=http://localhost
APP_TITLE=API Integration Readiness Agent

# --- Optional: better search (keyless DuckDuckGo is the default) ---
# TAVILY_API_KEY=
# SERPER_API_KEY=

# --- Optional: read-only Composio tool-call demo (demo/composio_demo.py) ---
# COMPOSIO_DEMO_TOOLKIT=github
# COMPOSIO_DEMO_USER_ID=default
