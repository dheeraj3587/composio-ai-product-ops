# Copy to .env and fill in. NEVER commit .env.

# --- LLM chain (OpenAI-compatible). Default: OpenRouter Opus 4.8 -> GPT-5-mini -> Gemini 2.5 Flash ---
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-opus-4.8
LLM_FALLBACK_PROVIDER=openrouter
LLM_FALLBACK_MODEL=openai/gpt-5-mini
LLM_FALLBACK2_PROVIDER=google
LLM_FALLBACK2_MODEL=gemini-2.5-flash
# Round-robin these providers as the lead per app (sharding) to spread rate limits:
LLM_SHARD_PROVIDERS=openrouter

# OpenRouter (https://openrouter.ai) — recommended primary
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace_me

# --- Composio (toolkit lookup + MCP hint) ---
COMPOSIO_API_KEY=replace_me

# --- Optional extra LLM providers (only used if you add them to the chain / sharding) ---
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GOOGLE_API_KEY=replace_me
# GOOGLE_MODEL=gemini-2.5-flash
# ZENMUX_BASE_URL=https://zenmux.ai/api/v1
# ZENMUX_API_KEY=replace_me
# AGENTROUTER_BASE_URL=https://agentrouter.org/v1
# AGENTROUTER_API_KEY=replace_me

# --- Optional: Browser Use Cloud verification loop (browser_verify.py, runs in .venv-browser) ---
# BROWSER_USE_API_KEY=replace_me

# --- Optional: better search (keyless DuckDuckGo is the default) ---
# TAVILY_API_KEY=
# SERPER_API_KEY=

# --- Optional attribution headers providers show on your dashboard ---
APP_PUBLIC_URL=http://localhost
APP_TITLE=API Integration Readiness Agent

# --- Optional: read-only Composio tool-call demo (demo/composio_demo.py) ---
# COMPOSIO_DEMO_TOOLKIT=github
# COMPOSIO_DEMO_USER_ID=default
